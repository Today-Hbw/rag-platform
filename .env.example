# rag-platform 配置模板 —— 复制为 .env 并填真实值；.env 不入库。
# 命名规则：pydantic-settings，前缀 RAG_ + 嵌套用双下划线 __。
# 例如 RAG_MYSQL__PASSWORD 对应 Settings.mysql.password。

# --- MySQL（元数据 / 状态机）---
RAG_MYSQL__HOST=10.0.0.1
RAG_MYSQL__PORT=3306
# 建议用最小权限应用账号，勿用 root（见 deploy/CREDENTIAL_ROTATION.md）
RAG_MYSQL__USER=rag_app
RAG_MYSQL__PASSWORD=change-me
RAG_MYSQL__DATABASE=hro_python
RAG_MYSQL__CHARSET=utf8mb4

# --- Redis（检索缓存）---
RAG_REDIS__HOST=10.0.0.2
RAG_REDIS__PORT=6379
RAG_REDIS__PASSWORD=change-me
RAG_REDIS__DB=0
RAG_REDIS__CACHE_TTL_MIN=3600
RAG_REDIS__CACHE_TTL_MAX=7200

# --- Embedding（火山方舟 / 豆包 multimodal）---
RAG_EMBEDDING__API_KEY=change-me
RAG_EMBEDDING__MODEL_ENDPOINT=ep-xxxxxxxx
RAG_EMBEDDING__URL=https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal
RAG_EMBEDDING__VECTOR_DIM=2048

# --- Qdrant（向量库）---
RAG_QDRANT__URL=http://qdrant:6333
RAG_QDRANT__COLLECTION=knowledge_documents

# --- 语雀 connector（仅 pipeline 需要）---
# API Token 与浏览器 Session Cookie；Cookie 是会话态、会过期。
RAG_YUQUE__TOKEN=change-me
RAG_YUQUE__COOKIE=change-me

# --- 检索参数（非密钥，可入库到 config.toml；此处给默认覆盖）---
RAG_SEARCH__RECALL_LIMIT=100
RAG_SEARCH__RRF_K=20
RAG_SEARCH__TITLE_WEIGHT=7

# --- 分块 ---
RAG_PIPELINE__CHUNK_SIZE=500
RAG_PIPELINE__CHUNK_OVERLAP=100

# --- 路径（显式 data_root，取代旧 SCRIPT_DIR 隐式契约）---
RAG_PATHS__DATA_ROOT=/mnt/rag/output

# --- RBAC（阶段 5，默认关闭以兼容旧行为）---
RAG_RBAC__ENABLED=false
# 携带用户角色的请求头（离线/调试模式下直接读它）
RAG_RBAC__ROLES_HEADER=X-Role-Ids
# 共享服务令牌（校验调用方是业务系统，置于 X-Service-Token 头）；空=不校验
RAG_RBAC__SERVICE_TOKEN=
# introspection（token→role_ids）：空=离线/调试模式（直接信 X-Role-Ids 头，等价旧行为）；
# 有值=在线模式（拿用户 Authorization: Bearer token 调它换 role_ids）
RAG_RBAC__INTROSPECT_URL=
RAG_RBAC__INTROSPECT_TIMEOUT=3.0
RAG_RBAC__SCOPE_CACHE_TTL=300
# 调 introspection 时附带的服务令牌（让业务系统信任 RAG）；空=不带
RAG_RBAC__INTROSPECT_SERVICE_TOKEN=
# 离线模式下 X-Role-Ids 缺失时的静态默认角色（JSON 数组）
RAG_RBAC__DEFAULT_ROLE_IDS=[]
